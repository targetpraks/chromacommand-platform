{
  "name": "chromacommand-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Unified RGB + Digital Menu + Audio control platform for Papa Pasta franchise network",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
