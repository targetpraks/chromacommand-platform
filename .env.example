# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chromacommand

# JWT (change in production)
JWT_SECRET=dev-secret-change-me
# Policy B (chosen): 1h access token, 30d refresh token. Operators leave the
# dashboard open for full shifts; refresh-rotation rotates these silently.
JWT_TTL=1h
REFRESH_TTL_DAYS=30

# MQTT Broker — local dev defaults to mosquitto in docker-compose
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=

# mTLS — only used when MQTT_BROKER_URL begins with mqtts://
# Paths to PEM-encoded files. EMQX/HiveMQ in production should require these.
MQTT_CLIENT_CERT=/etc/chromacommand/cert.pem
MQTT_CLIENT_KEY=/etc/chromacommand/key.pem
MQTT_CA_CERT=/etc/chromacommand/ca.pem
# Set to 1 ONLY for self-signed dev brokers. NEVER in production.
MQTT_INSECURE=0

# CORS origins (comma-separated)
DASHBOARD_ORIGIN=http://localhost:3000

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:4000

# Store ID (for edge gateway only)
STORE_ID=pp-a01
REGION_ID=cape-town

# Provisioning (PRD §22) — admin key used by /provision/issue
PROVISION_ADMIN_KEY=change-me-prod-only
PROVISION_BROKER_URL=mqtts://broker.chromacommand.io:8883
PROVISION_CA_PEM=

# Disable individual subsystems for tests / canary deploys
# DISABLE_SCHEDULER=1
# DISABLE_ALERTS=1

# Spotify Web API integration
# Create an app at https://developer.spotify.com/dashboard, set redirect URI
# to http://localhost:4000/spotify/callback (or your production URL).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:4000/spotify/callback
API_PUBLIC_URL=http://localhost:4000
