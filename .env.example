# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chromacommand

# JWT (change in production)
JWT_SECRET=dev-secret-change-me
JWT_TTL=12h

# MQTT Broker — local dev defaults to mosquitto in docker-compose
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# CORS origins (comma-separated)
DASHBOARD_ORIGIN=http://localhost:3000

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:4000

# Store ID (for edge gateway only)
STORE_ID=pp-a01
REGION_ID=cape-town
